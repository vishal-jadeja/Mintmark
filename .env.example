# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_hex_32
NEXTAUTH_URL=http://localhost:3000

# Encryption (AES-256-GCM) — use the same value as NEXTAUTH_SECRET or a separate 64-char hex string
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Email (Brevo)
EMAIL_FROM=your@email.com
BREVO_API_KEY=xkeysib-your_brevo_api_key_here

# App URL (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform OAuth — observation sources
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Platform OAuth — publishing platforms
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
MEDIUM_CLIENT_ID=
MEDIUM_CLIENT_SECRET=

# Trigger.dev (background jobs)
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

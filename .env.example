# =============================================================================
# Mintmark — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Source: app.supabase.com → Project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # anon/public key
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...                   # service_role key — NEVER expose to client

# -----------------------------------------------------------------------------
# Auth (NextAuth.js v5)
# NEXTAUTH_SECRET: openssl rand -hex 32
# NEXTAUTH_URL: exact production URL — must match Vercel domain
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=replace_with_openssl_rand_hex_32
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for OAuth tokens and API keys at rest)
# ENCRYPTION_KEY: openssl rand -hex 32  (must be exactly 64 hex characters)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=replace_with_openssl_rand_hex_32_giving_64_hex_chars

# -----------------------------------------------------------------------------
# Email (Brevo)
# Source: app.brevo.com → SMTP & API → API keys
# EMAIL_FROM must match your verified sending domain in Brevo
# -----------------------------------------------------------------------------
BREVO_API_KEY=xkeysib-your-brevo-api-key
EMAIL_FROM=notifications@yourdomain.com

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting + cache)
# Source: console.upstash.com → Your database → REST API tab
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX4Aasdf...

# -----------------------------------------------------------------------------
# App URL
# Used in email links and OAuth redirect URIs.
# Local: http://localhost:3000
# Production: https://your-domain.com (no trailing slash)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Trigger.dev (background jobs)
# Source: cloud.trigger.dev → Your project → Settings
# TRIGGER_SECRET_KEY: use tr_dev_... for local, tr_prod_... for production
# -----------------------------------------------------------------------------
TRIGGER_PROJECT_ID=proj_your_project_id
TRIGGER_SECRET_KEY=tr_dev_your_secret_key

# -----------------------------------------------------------------------------
# Optional: override the early access invite cap
# If not set, defaults to value in system_config table → EARLY_ACCESS_LIMIT
# env var → 100
# -----------------------------------------------------------------------------
# EARLY_ACCESS_LIMIT=100

# =============================================================================
# OAuth — Platform Connections
# All OAuth apps need their callback URL set to:
#   [NEXT_PUBLIC_APP_URL]/api/connections/[platform]/callback
#
# For local dev this is: http://localhost:3000/api/connections/[platform]/callback
# For production: https://your-domain.com/api/connections/[platform]/callback
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub
# Source: github.com → Settings → Developer settings → OAuth Apps
# Callback: [APP_URL]/api/connections/github/callback
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Gmail (Google Cloud Console)
# Source: console.cloud.google.com → APIs & Services → Credentials
# Enable the Gmail API. Scope: gmail.readonly
# Callback: [APP_URL]/api/connections/gmail/callback
# -----------------------------------------------------------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LinkedIn
# Source: developer.linkedin.com → My apps
# Products: Sign In with LinkedIn + Share on LinkedIn
# Callback: [APP_URL]/api/connections/linkedin/callback
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# X (Twitter)
# Source: developer.twitter.com → Projects & Apps
# App permissions: Read and Write. PKCE enabled.
# Callback: [APP_URL]/api/connections/x/callback
# -----------------------------------------------------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Medium
# Source: medium.com/me/settings → Security and apps → Developers
# Callback: [APP_URL]/api/connections/medium/callback
# -----------------------------------------------------------------------------
MEDIUM_CLIENT_ID=
MEDIUM_CLIENT_SECRET=
